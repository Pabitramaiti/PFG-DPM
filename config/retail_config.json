                                    "DTL_RECORD": {"DTL_REC_TYPE": "", "DTL_REC_SEQUENCE": "", "DTL_CLIENT_NUMBER": "", "DTL_CLIENT_NAME": "", "DTL_TEXT_1": "", "DTL_TEXT_2": "", "Heading1": "", "Heading2": "", "DTL_SECTION_AND_SUBSECTION_NAME": "", "DTL_Row_Indicator": "", "DTL_COLUMN_1_HEADER_1_TXT": "", "DTL_COLUMN_1_HEADER_2_TXT": "", "DTL_COLUMN_2_HEADER_1_TXT": "", "DTL_COLUMN_2_HEADER_2_TXT": "", "DTL_COLUMN_3_HEADER_1_TXT": "", "DTL_COLUMN_3_HEADER_2_TXT": "", "DTL_COLUMN_4_HEADER_1_TXT": "", "DTL_COLUMN_4_HEADER_2_TXT": "", "DTL_COLUMN_5_HEADER_1_TXT": "", "DTL_COLUMN_5_HEADER_2_TXT": "", "DTL_COLUMN_6_HEADER_1_TXT": "", "DTL_COLUMN_6_HEADER_2_TXT": "", "DTL_COLUMN_7_HEADER_1_TXT": "", "DTL_COLUMN_7_HEADER_2_TXT": "", "DTL_COLUMN_VALUES": {"ROW": []}},
                                    "CATEGORY_RECORDS": {"detail_table_type_1": [], "detail_table_type_2": [], "detail_table_type_3": []},
