                                "advisor_limit": 1,
                                "command": "SELECT  t1.partyid AS partyid_list, t3.partyidentifiervalue AS partyidentifiervalue_list FROM schema.partycommon t1 JOIN schema.partyclassification t2 ON t1.partyid = t2.partyid AND t2.partyclassificationvalue = 'Advisor' JOIN schema.partyidentifier t3 ON t1.partyid = t3.partyid AND t3.partyidentifiertype = 'OtherExternal'"
