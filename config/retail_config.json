                {
                    "name": "accountextraction",
                    "order": "2",
                    "initStep": "False",
                    "endStep": "False",
                    "sfKey": "SM_ARN_ACCOUNTEXTRACTION",
                    "sfNextKey":"SM_ARN_DRIVERCREATION",
                    "sfStepsToDone": {
                        "extractaccounts": {
                            "bucket": "",
                            "inputFile": "",
                            "ishouseholdneeded": "N",
                            "ismulticurrency": "N",
                            "account": {
                                "columns_list": "partyid, partyidentifiervalue",
                                "command": "SELECT t1.partyid, t1.partyorigin AS party_origin, t1.partyisparent AS party_isparent, t1.partyparentid AS party_parentid, t1.partyparentreference AS party_parentreference, t2.partyclassificationtype AS partyclassification_type, t2.partyclassificationvalue AS partyclassification_value, t3.partyidentifiervalue AS partyidentifier_value, t3.partyidentifiertype AS partyidentifier_type, t4.partycontactfirstname AS partycontact_firstname, t4.partycontactlastname AS partycontact_lastname, t4.partycontacttype AS partycontact_type, t5.partycontactaddressline1 AS partycontact_addressline1, t5.partycontactaddressline2 AS partycontact_addressline2, t5.partycontactaddressline3 AS partycontact_addressline3, t5.partycontactaddressline4 AS partycontact_addressline4 FROM schema.partycommon t1 JOIN schema.partyclassification t2 ON t1.partyid = t2.partyid AND t2.partyclassificationvalue = 'Account' JOIN schema.partyidentifier t3 ON t1.partyid = t3.partyid AND t3.partyidentifiertype = 'OtherExternal' JOIN schema.partycontact t4 ON t1.partyid = t4.partyid AND t4.partycontacttype = 'AccountHolder' JOIN schema.partycontactmailingaddress t5 ON t1.partyid = t5.partyid WHERE t1.partyparentid IN partyid_list"
                            },
                            "transaction": {
                                "command": "WITH BaseData AS (SELECT t1.transactionpartyidentifiervalue AS partyid, t1.transactionid AS transactionid, MAX(t2.TransactionPrimaryAssetClass) AS sectionheader, MAX(t2.transactioncategory) AS transactioncategory, MAX(t2.transactiontype) AS transactiontype, CASE WHEN COUNT(t3.transactionamounttype) > 0 THEN jsonb_object_agg(COALESCE(t3.transactionamounttype, ' ')::text, t3.transactionamountvalue) ELSE '{}'::jsonb END AS transactionamounts, MAX(t4.transactiondatetimevalue) AS transactiondate, MAX(t5.transactionpricevalue) AS transactionprice, CONCAT(CASE WHEN MAX(t6.transactioninstrumentidentifiervalue) IS NOT NULL THEN MAX(t6.transactioninstrumentidentifiervalue) || CASE WHEN STRING_AGG(DISTINCT CASE WHEN t7.transactionnarrativetype = 'MultiLineDescription' THEN t7.transactionnarrativevalue ELSE NULL END, '|') IS NOT NULL THEN '|' ELSE '' END ELSE '' END || NULLIF(STRING_AGG(DISTINCT CASE WHEN t7.transactionnarrativetype = 'MultiLineDescription' THEN t7.transactionnarrativevalue ELSE NULL END, '|'), '') ) AS description, MAX(CASE WHEN t7.transactionnarrativetype IN ('TransactionDescription', 'Holdings') THEN t7.transactionnarrativevalue ELSE NULL END) AS transactiondescription, CASE WHEN COUNT(t8.transactionquantitytype) > 0 THEN jsonb_object_agg(COALESCE(t8.transactionquantitytype, ' ')::text, COALESCE(t8.transactionquantityvalue::text, ' ')) ELSE '{}'::jsonb END AS transactionquantities FROM public.transactionparty t1 LEFT JOIN public.transactionevent t2 ON t1.transactionid = t2.transactionid LEFT JOIN public.transactionamount t3 ON t1.transactionid = t3.transactionid AND t3.transactionamounttype IN ('MarketValue', 'AssetClassTotalValue', 'NetAmount', 'NetAmountInDenominationCurrency') LEFT JOIN public.transactiondate t4 ON t1.transactionid = t4.transactionid AND t4.transactiondatetype IN ('SettlementDate') LEFT JOIN public.transactionprice t5 ON t1.transactionid = t5.transactionid AND t5.transactionpricetype IN ('MarketPrice', 'OrderPrice') LEFT JOIN public.transactioninstrument t6 ON t1.transactionid = t6.transactionid AND t6.transactioninstrumentrole IN ('PrimaryInstrument') LEFT JOIN public.transactionnarrative t7 ON t1.transactionid = t7.transactionid AND t7.transactionnarrativetype IN ('Holdings', 'TransactionDescription', 'MultiLineDescription') LEFT JOIN public.transactionquantity t8 ON t1.transactionid = t8.transactionid AND t8.transactionquantitytype IN ('PrimaryQuantity', 'TotalOrderQuantity') WHERE t1.transactionpartyidentifiervalue IN partyid AND t2.transactioncategory IN ('Transactions', 'Holdings') GROUP BY t1.transactionpartyidentifiervalue, t1.transactionid), CurrencyData AS (SELECT t1.transactionid, STRING_AGG(DISTINCT t3.transactionamountcurrency, '|') AS transactionamountcurrency FROM public.transactionamount t3 LEFT JOIN public.transactionparty t1 ON t3.transactionid = t1.transactionid WHERE t3.transactionamounttype IN ('MarketValue', 'AssetClassTotalValue', 'NetAmount', 'NetAmountInDenominationCurrency') GROUP BY t1.transactionid) SELECT bd.partyid, bd.transactionid, bd.sectionheader, bd.transactiondate, COALESCE(cd.transactionamountcurrency, '') AS transactionamountcurrency, bd.transactioncategory, bd.description, bd.transactiondescription, bd.transactionamounts, bd.transactionprice FROM BaseData bd LEFT JOIN CurrencyData cd ON bd.transactionid = cd.transactionid;"
                            },
                            "formats": {
                                "date": "%m/%d/%Y",
                                "currency": "$%.2f",
                                "decimal": "%.3f"
                            },
                            "driverlayout":[
                                {
                                    "STMT_RECORD": {"STMT_REC_TYPE": "", "STMT_REC_SEQUENCE": "", "STMT_CLIENT_NUMBER": "", "STMT_CLIENT_NAME": "", "STMT_STMT_APPLICATION": "", "STMT_PARENT_ID": "", "STMT_STMT_ID": "", "STMT_ACCOUNT_NUMBER": "", "STMT_BRANCH_NUMBER": "", "STMT_SALUTATION": "", "STMT_FIRST_NAME": "", "STMT_MIDDLE_NAME": "", "STMT_LAST_NAME": "", "STMT_ADDRESS_LINE_1": "", "STMT_ADDRESS_LINE_2": "", "STMT_ADDRESS_LINE_3": "", "STMT_ADDRESS_LINE_4": "", "STMT_ADDRESS_LINE_5": "", "STMT_ADDRESS_LINE_6": "", "STMT_ADDRESS_LINE_7": "", "STMT_ADDRESS_LINE_8": "", "STMT_CITY": "", "STMT_STATE": "", "STMT_COUNTRY_NAME": "", "STMT_ZIPCODE": "", "STMT_ZIP_4": "", "STMT_ZIP_DELIVERY_CODE": "", "STMT_ZIP_CHECK_DIGIT": "", "STMT_FRGN_IND": "", "STMT_REP_NAME": "", "STMT_REP_ID": "", "STMT_REP_ADRESS_LINE_1": "", "STMT_REP_ADRESS_LINE_2": "", "STMT_REP_ADRESS_LINE_3": "", "STMT_REP_EMAIL": "", "STMT_REP_PHONE": "", "STMT_RETURN_ADDRESS_LINE_1": "", "STMT_RETURN_ADDRESS_LINE_2": "", "STMT_RETURN_ADDRESS_LINE_3": "", "STMT_RETURN_ADDRESS_LINE_4": "", "STMT_RETURN_ADDRESS_LINE_5": "", "STMT_RETURN_ADDRESS_LINE_6": "", "STMT_DATE_FROM": "", "STMT_DATE_TO": "", "STMT_DATE3": "", "STMT_FONT_CHOICE": "", "STMT_USER_TEXT_VARIABLE_01": "", "STMT_USER_TEXT_VARIABLE_02": "", "STMT_USER_TEXT_VARIABLE_03": "", "STMT_USER_TEXT_VARIABLE_04": "", "STMT_USER_TEXT_VARIABLE_05": "", "STMT_USER_TEXT_VARIABLE_06": "", "STMT_USER_TEXT_VARIABLE_07": "", "STMT_USER_TEXT_VARIABLE_08": "", "STMT_USER_TEXT_VARIABLE_09": "", "STMT_USER_TEXT_VARIABLE_10": "", "STMT_USER_TEXT_VARIABLE_11": "", "STMT_USER_TEXT_VARIABLE_12": "", "STMT_USER_TEXT_VARIABLE_13": "", "STMT_USER_TEXT_VARIABLE_14": "", "STMT_USER_TEXT_VARIABLE_15": "", "STMT_USER_TEXT_VARIABLE_16": "", "STMT_USER_TEXT_VARIABLE_17": "", "STMT_USER_TEXT_VARIABLE_18": "", "STMT_USER_TEXT_VARIABLE_19": "", "STMT_USER_TEXT_VARIABLE_20": "", "STMT_USER_TEXT_VARIABLE_21": "", "STMT_USER_TEXT_VARIABLE_22": "", "STMT_USER_TEXT_VARIABLE_23": "",