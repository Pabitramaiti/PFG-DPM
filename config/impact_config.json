                    }
                },
                {
                    "name": "accountextraction",
                    "order": "2",
                    "initStep": "False",
                    "endStep": "False",
                    "sfKey": "SM_ARN_ACCOUNTEXTRACTION",
                    "sfNextKey":"SM_ARN_DRIVERCREATION",
                    "sfStepsToDone": {
                        "extractaccounts": {
                            "bucket": "",
                            "inputFile": "",
                            "ishouseholdneeded": "N",
                            "ismulticurrency": "N",
                            "account": {
                                "columns_list": "partyid, partyidentifiervalue",
                                "command": "SELECT t1.partyid, t1.partyorigin AS party_origin, t1.partyisparent AS party_isparent, t1.partyparentid AS party_parentid, t1.partyparentreference AS party_parentreference, t2.partyclassificationtype AS partyclassification_type, t2.partyclassificationvalue AS partyclassification_value, t3.partyidentifiervalue AS partyidentifier_value, t3.partyidentifiertype AS partyidentifier_type, t4.partycontactfirstname AS partycontact_firstname, t4.partycontactlastname AS partycontact_lastname, t4.partycontacttype AS partycontact_type, t5.partycontactaddressline1 AS partycontact_addressline1, t5.partycontactaddressline2 AS partycontact_addressline2, t5.partycontactaddressline3 AS partycontact_addressline3, t5.partycontactaddressline4 AS partycontact_addressline4 FROM schema.partycommon t1 JOIN schema.partyclassification t2 ON t1.partyid = t2.partyid AND t2.partyclassificationvalue = 'Account' JOIN schema.partyidentifier t3 ON t1.partyid = t3.partyid AND t3.partyidentifiertype = 'OtherExternal' JOIN schema.partycontact t4 ON t1.partyid = t4.partyid JOIN schema.partycontactmailingaddress t5 ON t1.partyid = t5.partyid WHERE t1.partyparentid IN partyid_list"
                            },
                            "transaction": {
                                "command": "WITH BaseData AS (SELECT t1.transactionpartyidentifiervalue AS partyid, t1.transactionid AS transactionid, MAX(t2.TransactionPrimaryAssetClass) AS sectionheader, MAX(t2.transactioncategory) AS transactioncategory, CASE WHEN COUNT(t4.transactionamounttype) > 0 THEN jsonb_object_agg(COALESCE(t4.transactionamounttype, ' ')::text, t4.transactionamountvalue) ELSE '{}'::jsonb END AS transactionamounts, MAX(t6.transactionpricevalue) AS transactionprice, MAX(t7.transactiondatetimevalue) AS transactiondate, CONCAT(NULLIF(STRING_AGG(DISTINCT t3.transactionnarrativevalue, '|'), '') || CASE WHEN MAX(t8.transactionidentifiervalue) IS NOT NULL THEN CASE WHEN STRING_AGG(DISTINCT t3.transactionnarrativevalue, '|') IS NOT NULL THEN '|' ELSE '' END || MAX(t8.transactionidentifiervalue) ELSE '' END || CASE WHEN STRING_AGG(DISTINCT t9.transactioninstrumentidentifiertype || ': ' || CAST(t9.transactioninstrumentidentifiervalue AS VARCHAR), '|') IS NOT NULL THEN CASE WHEN MAX(t8.transactionidentifiervalue) IS NOT NULL THEN '|' ELSE '' END || STRING_AGG(DISTINCT t9.transactioninstrumentidentifiertype || ': ' || CAST(t9.transactioninstrumentidentifiervalue AS VARCHAR), '|') ELSE '' END) AS description FROM schema.transactionparty t1 LEFT JOIN schema.transactionevent t2 ON t1.transactionid = t2.transactionid LEFT JOIN schema.transactionprice t6 ON t1.transactionid = t6.transactionid AND t6.transactionpricetype IN ('ClosingPrice') LEFT JOIN schema.transactiondate t7 ON t1.transactionid = t7.transactionid AND t7.transactiondatetype IN ('ClearingDate') LEFT JOIN schema.transactionidentifier t8 ON t1.transactionid = t8.transactionid AND t8.transactionidentifiertype IN ('ExternalReference') LEFT JOIN schema.transactioninstrument t9 ON t1.transactionid = t9.transactionid AND t9.transactioninstrumentrole IN ('PrimaryInstrument') LEFT JOIN schema.transactionamount t4 ON t1.transactionid = t4.transactionid AND t4.transactionamounttype IN ('OpeningBalance','ClosingBalance','LongMarketValue','ShortMarketValue', 'TotalCredit', 'TotalDebit') LEFT JOIN schema.transactionnarrative t3 ON t1.transactionid = t3.transactionid AND t3.transactionnarrativetype IN ('MultiLineDescription') WHERE t1.transactionpartyidentifiervalue IN partyid GROUP BY t1.transactionpartyidentifiervalue, t1.transactionid), CurrencyData AS (SELECT t1.transactionid, STRING_AGG(DISTINCT t4.transactionamountcurrency, '|') AS transactionamountcurrency FROM schema.transactionamount t4 LEFT JOIN schema.transactionparty t1 ON t4.transactionid = t1.transactionid WHERE t4.transactionamounttype IN ('OpeningBalance', 'ClosingBalance', 'LongMarketValue', 'ShortMarketValue', 'TotalCredit', 'TotalDebit') GROUP BY t1.transactionid) SELECT bd.partyid, bd.transactionid, bd.sectionheader, COALESCE(cd.transactionamountcurrency, '') as transactionamountcurrency, bd.transactiondate, bd.description, bd.transactioncategory, bd.transactionprice, bd.transactionamounts FROM BaseData bd LEFT JOIN CurrencyData cd ON bd.transactionid = cd.transactionid"
                            },
                            "formats": {
                                "date": "%m/%d",
                                "currency": "$%.2f",
                                "decimal": "%.3f"
                            },                            
                            "driverlayout":[
                                {
