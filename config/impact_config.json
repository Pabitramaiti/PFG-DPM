                                    "DTL_RECORD": {"DTL_REC_TYPE": "", "DTL_REC_SEQUENCE": "", "DTL_CLIENT_NUMBER": "", "DTL_CLIENT_NAME": "", "DTL_TEXT_1": "", "DTL_TEXT_2": "", "Heading1": "", "Heading2": "", "DTL_SECTION_AND_SUBSECTION_NAME": "", "DTL_Row_Indicator": "", "DTL_COLUMN_1_HEADER_1_TXT": "", "DTL_COLUMN_1_HEADER_2_TXT": "", "DTL_COLUMN_2_HEADER_1_TXT": "", "DTL_COLUMN_2_HEADER_2_TXT": "", "DTL_COLUMN_3_HEADER_1_TXT": "", "DTL_COLUMN_3_HEADER_2_TXT": "", "DTL_COLUMN_4_HEADER_1_TXT": "", "DTL_COLUMN_4_HEADER_2_TXT": "", "DTL_COLUMN_5_HEADER_1_TXT": "", "DTL_COLUMN_5_HEADER_2_TXT": "", "DTL_COLUMN_6_HEADER_1_TXT": "", "DTL_COLUMN_6_HEADER_2_TXT": "", "DTL_COLUMN_7_HEADER_1_TXT": "", "DTL_COLUMN_7_HEADER_2_TXT": "", "DTL_COLUMN_VALUES": {"ROW": []}},
                                    "CATEGORY_RECORDS": {"detail_table_type_1": [], "detail_table_type_2": [], "detail_table_type_3": []},
									"TRANSACTIONS_DTL_RECORD": {"TradeActivities": {"Heading": "Trades, Clearance and Adjustment Activities","OpeningBalance":[["OPENING BALANCE","COLUMN_2_ROW_1","","",""],["Amount","COLUMN_7_ROW_1","transactionamounts.OpeningBalance","currency",""]], "Detail": [["Clear Date","COLUMN_1_ROW_1","transactiondate","date",""],["Description","COLUMN_2_ROW_1","description","",""],["Price or Explanation","COLUMN_3_ROW_1","transactionprice","decimal",""],["Bought/Received Long","COLUMN_4_ROW_1","transactionamounts.LongMarketValue","currency",""],["Sold/Delivered Short","COLUMN_5_ROW_1","transactionamounts.ShortMarketValue","currency",""],["Debit Amount","COLUMN_6_ROW_1","transactionamounts.TotalDebit","currency",""],["Credit Amount","COLUMN_7_ROW_1","transactionamounts.TotalCredit","currency",""]] ,"ClosingBalance":[["CLOSING BALANCE","COLUMN_2_ROW_1","","",""],["Amount","COLUMN_7_ROW_1","transactionamounts.ClosingBalance","currency",""]]}, "CustomerPositions": {"Heading": "Customer Positions","Detail": [["Clear Date","COLUMN_1_ROW_1","transactiondate","date",""],["Description","COLUMN_2_ROW_1","description","",""],["Price or Explanation","COLUMN_3_ROW_1","transactionprice","decimal",""],["Bought/Received Long","COLUMN_4_ROW_1","transactionamounts.LongMarketValue","currency",""],["Sold/Delivered Short","COLUMN_5_ROW_1","transactionamounts.ShortMarketValue","currency",""],["Debit Amount","COLUMN_6_ROW_1","transactionamounts.TotalDebit","currency",""],["Credit Amount","COLUMN_7_ROW_1","transactionamounts.TotalCredit","currency",""]]}, "OptionsPositions": {"Heading": "OTC Options Positions","Detail": [["Clear Date","COLUMN_1_ROW_1","transactiondate","date",""],["Description","COLUMN_2_ROW_1","description","",""],["Price or Explanation","COLUMN_3_ROW_1","transactionprice","decimal",""],["Bought/Received Long","COLUMN_4_ROW_1","transactionamounts.LongMarketValue","currency",""],["Sold/Delivered Short","COLUMN_5_ROW_1","transactionamounts.ShortMarketValue","currency",""],["D