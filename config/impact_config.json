        {
            "filename": "(|CIT_TEST_)(IMPACTSTATEMENT)_[0-9]{4}-[0-1][0-9]-[0-3][0-9]T[0-2][0-9][0-5][0-9][0-5][0-9].trigger",
            "fileType": "txt",
            "StepFunction": [
                {
                    "name": "advisorextraction",
                    "order": "1",
                    "initStep": "True",
                    "endStep": "False",
                    "sfKey": "SM_ARN_ADVISOREXTRACTION",
                    "sfNextKey": "SM_ARN_ACCOUNTEXTRACTION",
                    "sfStepsToDone": {
                        "createadvisorlist": {
                            "wipPath": "impact/wip",
                            "outputFile": "advisors_list",
                            "outputFileType": "json",
                            "advisor": {
                                "columns_list": "partyid_list, partyidentifiervalue_list",
                                "advisor_limit": 1,
                                "command": "SELECT  t1.partyid AS partyid_list, t3.partyidentifiervalue AS partyidentifiervalue_list FROM schema.partycommon t1 JOIN schema.partyclassification t2 ON t1.partyid = t2.partyid AND t2.partyclassificationvalue = 'Advisor' JOIN schema.partyidentifier t3 ON t1.partyid = t3.partyid AND t3.partyidentifiertype = 'OtherExternal'"
                            },
                            "columns": {
                                "attributes": [{"name": "partyid", "type": "String", "primary_key": true}, {"name": "json_driver", "type": "String"}]
                            },
